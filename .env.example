# Puerto en el que se ejecutará el servidor
PORT=3000

# Entorno de la aplicación (development, production, test)
NODE_ENV=development

# URI de conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/chatbot

# Secreto para firmar tokens de sesión de Auth.js
# En producción, debe ser una cadena aleatoria segura
AUTH_SECRET=your-super-secret-key-for-development-only